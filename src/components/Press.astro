---
/**
 * Press component - media mentions section.
 * Simple logo/name showcase of press coverage.
 */
---

<section class="py-10 border-t border-b border-line-soft bg-bg-soft">
  <div class="container-custom">
    <div class="text-center text-xs uppercase tracking-[0.18em] text-ink-mute mb-6 font-semibold" data-i18n="press.title">
      Hablan de nosotros
    </div>
    
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      <div class="font-serif text-xl text-ink-soft font-bold opacity-55 hover:opacity-100 transition-opacity">
        La Vanguardia
      </div>
      <div class="font-serif text-xl text-ink-soft italic font-normal opacity-55 hover:opacity-100 transition-opacity">
        El País
      </div>
      <div class="font-sans text-xl text-ink-soft font-normal opacity-55 hover:opacity-100 transition-opacity">
        El Economista
      </div>
      <div class="font-serif text-xl text-ink-soft font-bold opacity-55 hover:opacity-100 transition-opacity">
        Expansión
      </div>
      <div class="font-serif text-xl text-ink-soft italic font-normal opacity-55 hover:opacity-100 transition-opacity">
        La Razón
      </div>
    </div>
  </div>
</section>
