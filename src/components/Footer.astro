---
/**
 * Footer component - site-wide footer with navigation, contact info, and legal links.
 * Semantic HTML5 footer element with proper heading hierarchy.
 */

import { siteConfig } from '@data/siteConfig';
---

<footer class="bg-[#1c2929] text-bg/70 pt-16 pb-8">
  <div class="container-custom">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-12 mb-12">
      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 no-underline text-bg mb-4 group" aria-label="Solfy">
          <svg class="h-10 w-auto" viewBox="0 0 950 300" role="img" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="footerLogoGradient" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#d4f767" />
                <stop offset="100%" stop-color="#9ad4ff" />
              </linearGradient>
