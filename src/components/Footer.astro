199219 z" />
          </svg>
          <span class="sr-only">Solfy</span>
        </a>
        
        <p class="text-sm leading-relaxed mb-6 max-w-xs" data-i18n="footer.brandDescription">
          Instaladores de placas solares y aerotermia en toda España. Estudio gratuito, gestión completa.
        </p>
        
        <div class="text-sm mb-2 text-bg/85">
          <a href={`tel:${siteConfig.phone}`} class="text-inherit no-underline hover:text-brand-sage transition-colors">{siteConfig.phone.replace('+34', '')}</a>
        </div>
        <div class="text-sm text-bg/85">
          <a href={`mailto:${siteConfig.email}`} class="text-inherit no-underline hover:text-brand-sage transition-colors">{siteConfig.email}</a>
        </div>
      </div>

      <!-- Solutions column -->
      <div>
        <h4 class="font-serif text-bg text-lg font-normal mb-5 tracking-tight">Soluciones</h4>
        <ul class="list-none m-0 p-0">
          <li class="mb-3"><a href="/products#residential" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Viviendas unifamiliares</a></li>
          <li class="mb-3"><a href="/products#communities" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Comunidades de vecinos</a></li>
          <li class="mb-3"><a href="/products#business" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Empresas e industria</a></li>
          <li class="mb-3"><a href="/products#aerothermal" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Aerotermia</a></li>
          <li class="mb-3"><a href="/products#batteries" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Baterías solares</a></li>
          <li class="mb-3"><a href="/products#chargers" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Cargadores eléctricos</a></li>
        </ul>
      </div>

      <!-- About column -->
      <div>
        <h4 class="font-serif text-bg text-lg font-normal mb-5 tracking-tight">Solfy</h4>
        <ul class="list-none m-0 p-0">
          <li class="mb-3"><a href="/about#method" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">El método</a></li>
          <li class="mb-3"><a href="/about#installations" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Instalaciones realizadas</a></li>
          <li class="mb-3"><a href="/#testimonials" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Opiniones</a></li>
          <li class="mb-3"><a href="/about#press" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Apariciones en prensa</a></li>
          <li class="mb-3"><a href="/about#wiki" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Wiki Solar</a></li>
        </ul>
      </div>

      <!-- Help column -->
      <div>
        <h4 class="font-serif text-bg text-lg font-normal mb-5 tracking-tight">Ayuda</h4>
        <ul class="list-none m-0 p-0">
          <li class="mb-3"><a href="/contact" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Contacto</a></li>
          <li class="mb-3"><a href="/contact#client-area" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Área clientes</a></li>
          <li class="mb-3"><a href="/about#subsidies" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Subvenciones</a></li>
          <li class="mb-3"><a href="/#faq" class="text-bg/60 no-underline text-sm hover:text-brand-sage transition-colors">Preguntas frecuentes</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-bg/[0.08] flex flex-wrap gap-4 justify-between items-center text-xs text-bg/45">
      <div>
        © Solfy {new Date().getFullYear()}
      </div>
      
      <div class="flex gap-6 flex-wrap">
        <a href="/legal" data-i18n="footer.legal" class="text-inherit no-underline hover:text-brand-sage transition-colors">Nota legal</a>
        <a href="/privacy" data-i18n="footer.privacy" class="text-inherit no-underline hover:text-brand-sage transition-colors">Privacidad</a>
        <a href="/cookies" data-i18n="footer.cookies" class="text-inherit no-underline hover:text-brand-sage transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
