        <span class="sr-only">Solfy</span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden lg:flex gap-8 list-none m-0">
        <li><a href="/#solutions" data-i18n="header.nav.solutions" class="text-ink no-underline text-sm font-medium hover:text-brand-sage-deep transition-colors relative after:absolute after:left-0 after:-bottom-1.5 after:w-0 after:h-0.5 after:bg-gradient-brand after:rounded-sm after:transition-all hover:after:w-full">Soluciones</a></li>
        <li><a href="/#method" data-i18n="header.nav.method" class="text-ink no-underline text-sm font-medium hover:text-brand-sage-deep transition-colors relative after:absolute after:left-0 after:-bottom-1.5 after:w-0 after:h-0.5 after:bg-gradient-brand after:rounded-sm after:transition-all hover:after:w-full">Cómo trabajamos</a></li>
        <li><a href="/#coverage" data-i18n="header.nav.coverage" class="text-ink no-underline text-sm font-medium hover:text-brand-sage-deep transition-colors relative after:absolute after:left-0 after:-bottom-1.5 after:w-0 after:h-0.5 after:bg-gradient-brand after:rounded-sm after:transition-all hover:after:w-full">Dónde llegamos</a></li>
        <li><a href="/#faq" data-i18n="header.nav.faq" class="text-ink no-underline text-sm font-medium hover:text-brand-sage-deep transition-colors relative after:absolute after:left-0 after:-bottom-1.5 after:w-0 after:h-0.5 after:bg-gradient-brand after:rounded-sm after:transition-all hover:after:w-full">Dudas frecuentes</a></li>
        <li><a href="/#testimonials" data-i18n="header.nav.testimonials" class="text-ink no-underline text-sm font-medium hover:text-brand-sage-deep transition-colors relative after:absolute after:left-0 after:-bottom-1.5 after:w-0 after:h-0.5 after:bg-gradient-brand after:rounded-sm after:transition-all hover:after:w-full">Clientes</a></li>
      </ul>

      <!-- Right side actions -->
      <div class="flex items-center gap-3">
        <div class="hidden lg:flex items-center gap-2">
          <label for="language-select" class="sr-only" data-i18n="header.language">Idioma</label>
          <select id="language-select" class="border border-line px-3 py-2 rounded-pill bg-bg text-sm text-ink focus:outline-none focus:ring-2 focus:ring-brand-sage-deep transition-colors">
            <option value="es">Español</option>
            <option value="ca">Català</option>
            <option value="en">English</option>
            <option value="de">Deutsch</option>
            <option value="fr">Français</option>
            <option value="ru">Русский</option>
          </select>
        </div>

        <!-- CTA Button (hidden on mobile) -->
        <a href="/contact" data-i18n="header.cta" class="hidden md:inline-flex bg-gradient-brand text-ink no-underline px-5 py-3 rounded-pill text-sm font-semibold transition-all hover:-translate-y-0.5 hover:brightness-105 whitespace-nowrap">
          Estudio gratuito
        </a>

        <!-- Mobile menu toggle -->
        <button 
          id="mobile-menu-toggle" 
          class="lg:hidden bg-bg-soft border-0 w-10 h-10 rounded-pill flex items-center justify-center cursor-pointer flex-col gap-1"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
        >
          <span class="w-4 h-0.5 bg-ink rounded-sm"></span>
          <span class="w-4 h-0.5 bg-ink rounded-sm"></span>
          <span class="w-4 h-0.5 bg-ink rounded-sm"></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile Navigation Overlay -->
<aside 
  id="mobile-nav" 
  class="fixed top-0 -right-full w-[88%] max-w-[360px] h-screen bg-bg z-[200] pt-20 px-8 pb-8 transition-all duration-[350ms] ease-out overflow-y-auto shadow-2xl"
  role="dialog"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <button 
    id="mobile-close" 
    class="absolute top-6 right-6 bg-bg-soft border-0 text-2xl cursor-pointer text-ink w-10 h-10 rounded-pill flex items-center justify-center"
    aria-label="Cerrar menú"
  >
    ×
  </button>
  
  <nav>
    <ul class="list-none m-0 p-0">
      <li class="border-b border-line-soft">
        <a href="/#solutions" class="block py-5 text-ink no-underline font-serif text-2xl font-normal tracking-tight">Soluciones</a>
      </li>
      <li class="border-b border-line-soft">
        <a href="/#method" class="block py-5 text-ink no-underline font-serif text-2xl font-normal tracking-tight">Cómo trabajamos</a>
      </li>
      <li class="border-b border-line-soft">
        <a href="/#coverage" class="block py-5 text-ink no-underline font-serif text-2xl font-normal tracking-tight">Dónde llegamos</a>
      </li>
      <li class="border-b border-line-soft">
        <a href="/#faq" class="block py-5 text-ink no-underline font-serif text-2xl font-normal tracking-tight">Dudas frecuentes</a>
      </li>
      <li class="border-b border-line-soft">
        <a href="/#testimonials" class="block py-5 text-ink no-underline font-serif text-2xl font-normal tracking-tight">Clientes</a>
      </li>
      <li class="border-b border-line-soft">
        <a href="/contact" class="block py-5 text-ink no-underline font-serif text-2xl font-normal tracking-tight" data-i18n="header.cta">Estudio gratuito</a>
      </li>
    </ul>

    <div class="mt-8">
      <label for="language-select-mobile" class="block text-sm font-medium text-ink mb-2" data-i18n="header.language">Idioma</label>
      <select id="language-select-mobile" class="w-full border border-line px-3 py-3 rounded-2xl bg-bg text-ink focus:outline-none focus:ring-2 focus:ring-brand-sage-deep transition-colors">
        <option value="es">Español</option>
        <option value="ca">Català</option>
        <option value="en">English</option>
        <option value="de">Deutsch</option>
        <option value="fr">Français</option>
        <option value="ru">Русский</option>
      </select>
    </div>
  </nav>
</aside>

<!-- Scrim/Backdrop -->
<div 
  id="mobile-scrim" 
  class="fixed inset-0 bg-ink/35 z-[150] opacity-0 invisible transition-all duration-300 backdrop-blur-sm"
  aria-hidden="true"
></div>

<script>
  // Mobile menu interaction - minimal client-side JS
  const toggle = document.getElementById('mobile-menu-toggle');
  const nav = document.getElementById('mobile-nav');
  const close = document.getElementById('mobile-close');
  const scrim = document.getElementById('mobile-scrim');
  const navLinks = nav?.querySelectorAll('a');

  function openNav() {
    nav?.classList.remove('-right-full');
    nav?.classList.add('right-0');
    nav?.setAttribute('aria-hidden', 'false');
    scrim?.classList.remove('invisible', 'opacity-0');
    scrim?.classList.add('visible', 'opacity-100');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeNav() {
    nav?.classList.add('-right-full');
    nav?.classList.remove('right-0');
    nav?.setAttribute('aria-hidden', 'true');
    scrim?.classList.add('invisible', 'opacity-0');
    scrim?.classList.remove('visible', 'opacity-100');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openNav);
  close?.addEventListener('click', closeNav);
  scrim?.addEventListener('click', closeNav);
  navLinks?.forEach(link => link.addEventListener('click', closeNav));
</script>
