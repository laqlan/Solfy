---
/**
 * Hero component - main hero section for homepage.
 * Features headline, stats, CTAs, and visual illustration.
 * Uses semantic HTML with proper heading hierarchy (h1).
 */
---

<section class="relative pt-16 pb-16 md:pt-22 md:pb-20 overflow-hidden">
  <!-- Background video layer -->
  <div class="absolute inset-0 overflow-hidden">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      src="/videos/Video_portada_Web%202.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="absolute inset-0 bg-slate-950/70 md:bg-slate-950/45"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/95 via-transparent to-transparent"></div>
  </div>

  <!-- Background gradient orbs -->
  <div class="absolute top-[-20%] right-[-10%] w-[700px] h-[700px] pointer-events-none z-10 opacity-80">
    <div class="w-full h-full bg-[radial-gradient(circle,rgba(232,216,96,0.18),transparent_60%)]"></div>
  </div>
  <div class="absolute bottom-[-30%] left-[-15%] w-[600px] h-[600px] pointer-events-none z-10 opacity-80">
    <div class="w-full h-full bg-[radial-gradient(circle,rgba(123,197,220,0.18),transparent_60%)]"></div>
  </div>

  <div class="container-custom relative z-20">
    <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">
      <!-- Left column - Content -->
      <div>
        <div class="eyebrow">
          <span data-i18n="hero.eyebrow">Energía solar para tu hogar</span>
        </div>

        <h1 class="font-serif text-[clamp(2.6rem,7vw,4.8rem)] font-normal leading-[1.02] tracking-tight mb-6 text-white" data-i18n="hero.title">
          Tu factura de luz, <em class="italic gradient-text">resuelta</em>.
        </h1>

        <p class="text-lg text-slate-200/90 leading-relaxed mb-9 max-w-[520px]" data-i18n="hero.description">
          Estudio personalizado y gratuito. Instalación llave en mano. Garantía de hasta 25 años. Y cobertura en toda España.
        </p>

        <!-- Stats grid -->
        <div class="grid grid-cols-3 gap-6 py-6 border-t border-b border-line mb-9">
          <div>
            <div class="font-serif text-[clamp(1.6rem,4vw,2.3rem)] font-normal text-white tracking-tight leading-none mb-2" data-i18n="hero.stats.fundingValue">
              desde <em class="italic text-brand-sage-deep">39€</em>
            </div>
            <div class="text-xs text-slate-200/70 uppercase tracking-wider font-medium" data-i18n="hero.stats.fundingLabel">al mes financiación</div>
          </div>
          <div>
            <div class="font-serif text-[clamp(1.6rem,4vw,2.3rem)] font-normal text-white tracking-tight leading-none mb-2" data-i18n="hero.stats.savingValue">
              hasta <em class="italic text-brand-sage-deep">90%</em>
            </div>
            <div class="text-xs text-slate-200/70 uppercase tracking-wider font-medium" data-i18n="hero.stats.savingLabel">menos en tu factura</div>
          </div>
          <div>
            <div class="font-serif text-[clamp(1.6rem,4vw,2.3rem)] font-normal text-white tracking-tight leading-none mb-2" data-i18n="hero.stats.guaranteeValue">
              <em class="italic text-brand-sage-deep">25</em> años
            </div>
            <div class="text-xs text-slate-200/70 uppercase tracking-wider font-medium" data-i18n="hero.stats.guaranteeLabel">de garantía</div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary" data-i18n="hero.primaryCta">
            Solicita tu estudio
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <a href="/#method" class="btn-ghost" data-i18n="hero.secondaryCta">
            Cómo lo hacemos
          </a>
        </div>
      </div>

      <!-- Right column - Visual graphic overlay -->
      <div class="relative aspect-[4/5] max-h-[580px] rounded-card overflow-hidden bg-gradient-to-br from-brand-yellow-soft via-[#c5dec0] to-brand-sky shadow-lift">
        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_18%,rgba(255,255,255,0.5)_0%,transparent_35%),radial-gradient(circle_at_80%_75%,rgba(255,255,255,0.3)_0%,transparent_50%)]"></div>

        <!-- Sun illustration -->
        <div class="absolute top-[14%] right-[18%] w-28 h-28 rounded-full z-10 animate-pulse" style="background: radial-gradient(circle at 35% 35%, #fff5b8, #e8d860 60%, #d4c54a); box-shadow: 0 0 60px rgba(232,216,96,0.5), 0 0 100px rgba(232,216,96,0.3);"></div>

        <!-- Solar panels illustration -->
        <div class="absolute bottom-[17%] left-1/2 -translate-x-1/2 w-[70%] z-20" style="transform: translateX(-50%) perspective(900px) rotateX(52deg);">
          <div class="grid grid-cols-4 gap-[5px] mb-[5px]">
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
          </div>
          <div class="grid grid-cols-4 gap-[5px] mb-[5px]">
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
          </div>
          <div class="grid grid-cols-4 gap-[5px]">
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
            <div class="aspect-square bg-gradient-to-br from-[#2a3a4a] to-[#3a4f5e] border border-white/15 rounded-[3px]"></div>
          </div>
        </div>

        <!-- Stats card -->
        <div class="absolute bottom-6 left-6 right-6 bg-bg/95 backdrop-blur-md rounded-2xl p-6 z-30 shadow-lg">
          <div class="text-xs uppercase tracking-[0.14em] text-ink-mute mb-2 font-semibold">Ahorro medio anual</div>
          <div class="font-serif text-4xl font-normal text-ink leading-none tracking-tight mb-2">
            <em class="italic gradient-text">1.247€</em>
          </div>
          <div class="text-sm text-ink-soft">en una vivienda unifamiliar tipo</div>
        </div>
      </div>
    </div>
  </div>
</section>
